<Window x:Class="GenshinChatTranslator.App.LlmConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource LlmConfigTitle}"
        SizeToContent="Height"
        Width="520"
        MinWidth="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F6F7FA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="104" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Foreground="#5B6472"
                   Text="{DynamicResource LlmConfigUrlLabel}" />
        <TextBox x:Name="EndpointTextBox"
                 Grid.Row="0"
                 Grid.Column="1"
                 Height="34"
                 Margin="0,0,0,12"
                 Padding="8,4"
                 VerticalContentAlignment="Center" />

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Foreground="#5B6472"
                   Text="{DynamicResource LlmConfigApiKeyLabel}" />
        <PasswordBox x:Name="ApiKeyPasswordBox"
                     Grid.Row="1"
                     Grid.Column="1"
                     Height="34"
                     Margin="0,0,0,12"
                     Padding="8,4"
                     VerticalContentAlignment="Center" />

        <TextBlock Grid.Row="2"
                   Grid.Column="1"
                   Margin="0,0,0,12"
                   Foreground="#6B7280"
                   TextWrapping="Wrap"
                   Text="{DynamicResource LlmConfigApiKeyHint}" />

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Foreground="#5B6472"
                   Text="{DynamicResource LlmConfigModelLabel}" />
        <TextBox x:Name="ModelTextBox"
                 Grid.Row="3"
                 Grid.Column="1"
                 Height="34"
                 Margin="0,0,0,12"
                 Padding="8,4"
                 VerticalContentAlignment="Center" />

        <DockPanel Grid.Row="4"
                   Grid.ColumnSpan="2"
                   LastChildFill="False">
            <TextBlock x:Name="StatusTextBlock"
                       MaxWidth="300"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="#374151"
                       TextWrapping="Wrap" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button x:Name="CancelButton"
                        MinWidth="84"
                        Height="34"
                        Padding="14,0"
                        Click="CancelButton_Click"
                        Content="{DynamicResource LlmConfigCancelButton}" />
                <Button x:Name="SaveButton"
                        MinWidth="84"
                        Height="34"
                        Margin="8,0,0,0"
                        Padding="14,0"
                        Click="SaveButton_Click"
                        Content="{DynamicResource LlmConfigSaveButton}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
