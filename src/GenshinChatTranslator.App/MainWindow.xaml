<Window x:Class="GenshinChatTranslator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Icon="Assets/logo.ico"
        SizeToContent="Height"
        MinHeight="220"
        MinWidth="680"
        Width="780"
        Background="#F6F7FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{DynamicResource AppTitle}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,16,0"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       Foreground="#1F2937" />

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <CheckBox x:Name="DebugModeCheckBox"
                          Margin="0,0,18,0"
                          VerticalAlignment="Center"
                          Checked="DebugModeCheckBox_CheckedChanged"
                          Unchecked="DebugModeCheckBox_CheckedChanged"
                          Content="{DynamicResource DebugModeLabel}" />
                <TextBlock Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="#5B6472"
                           Text="{DynamicResource UiLanguageLabel}" />
                <Button x:Name="ChineseLanguageButton"
                        MinWidth="56"
                        Height="32"
                        Padding="10,0"
                        Tag="zh-CN"
                        Click="LanguageButton_Click"
                        Content="{DynamicResource UiLanguageChineseButton}" />
                <Button x:Name="JapaneseLanguageButton"
                        MinWidth="56"
                        Height="32"
                        Margin="6,0,0,0"
                        Padding="10,0"
                        Tag="ja-JP"
                        Click="LanguageButton_Click"
                        Content="{DynamicResource UiLanguageJapaneseButton}" />
                <Button x:Name="EnglishLanguageButton"
                        MinWidth="56"
                        Height="32"
                        Margin="6,0,0,0"
                        Padding="10,0"
                        Tag="en-US"
                        Click="LanguageButton_Click"
                        Content="{DynamicResource UiLanguageEnglishButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,0,0,18"
              HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="ToggleButton"
                        MinWidth="112"
                        Height="36"
                        Padding="18,0"
                        Click="ToggleButton_Click"
                        Content="{DynamicResource StartButton}" />
                <TextBlock Margin="22,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="#5B6472"
                           Text="{DynamicResource TranslationTargetLanguageLabel}" />
                <ComboBox x:Name="TranslationTargetLanguageComboBox"
                          Width="96"
                          Height="36"
                          VerticalContentAlignment="Center"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="TranslationTargetLanguageComboBox_SelectionChanged" />
                <Button x:Name="SnapshotButton"
                        MinWidth="112"
                        Height="36"
                        Margin="12,0,0,0"
                        Padding="18,0"
                        Click="SnapshotButton_Click"
                        Content="{DynamicResource SnapshotButton}" />
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center"
                           Foreground="#5B6472"
                           Text="{DynamicResource OcrEngineLabel}" />
                <ComboBox x:Name="OcrEngineComboBox"
                          Width="160"
                          Height="36"
                          Margin="8,0,0,0"
                          VerticalContentAlignment="Center"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="OcrEngineComboBox_SelectionChanged" />
                <TextBlock Margin="24,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="#5B6472"
                           Text="{DynamicResource TranslationEngineLabel}" />
                <ComboBox x:Name="TranslationEngineComboBox"
                          Width="176"
                          Height="36"
                          VerticalContentAlignment="Center"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="TranslationEngineComboBox_SelectionChanged" />
                <Button x:Name="ConfigureLlmButton"
                        MinWidth="96"
                        Height="36"
                        Margin="8,0,0,0"
                        Padding="14,0"
                        Visibility="Collapsed"
                        Click="ConfigureLlmButton_Click"
                        Content="{DynamicResource ConfigureLlmButton}" />
            </StackPanel>
        </Grid>

        <Border x:Name="DebugDetailsBorder"
                Grid.Row="2"
                Padding="18"
                Background="White"
                BorderBrush="#D9DEE8"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,0,12"
                           Foreground="#5B6472"
                           Text="{DynamicResource TargetLabel}" />
                <TextBlock x:Name="TargetTextBlock"
                           Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap"
                           Foreground="#111827" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,0,12"
                           Foreground="#5B6472"
                           Text="{DynamicResource CaptureLabel}" />
                <TextBlock x:Name="CaptureTextBlock"
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,0,0,12"
                           Foreground="#111827" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,0,12"
                           Foreground="#5B6472"
                           Text="{DynamicResource RoiLabel}" />
                <TextBlock x:Name="RoiTextBlock"
                           Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,0,0,12"
                           Foreground="#111827" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,0,12"
                           Foreground="#5B6472"
                           Text="{DynamicResource OcrLabel}" />
                <TextBlock x:Name="OcrTextBlock"
                           Grid.Row="3"
                           Grid.Column="1"
                           Margin="0,0,0,12"
                           Foreground="#111827" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,0,12"
                           Foreground="#5B6472"
                           Text="{DynamicResource TranslationLabel}" />
                <TextBlock x:Name="TranslationTextBlock"
                           Grid.Row="4"
                           Grid.Column="1"
                           Margin="0,0,0,12"
                           Foreground="#111827" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,0,12"
                           Foreground="#5B6472"
                           Text="{DynamicResource RecognitionSummaryLabel}" />
                <TextBlock x:Name="RecognitionSummaryTextBlock"
                           Grid.Row="5"
                           Grid.Column="1"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap"
                           Foreground="#111827" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Foreground="#5B6472"
                           Text="{DynamicResource LatencyLabel}" />
                <TextBlock x:Name="LatencyTextBlock"
                           Grid.Row="6"
                           Grid.Column="1"
                           TextWrapping="Wrap"
                           Foreground="#111827" />
            </Grid>
        </Border>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Margin="0,18,0,0"
                   Foreground="#374151"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
