<Window x:Class="GenshinChatTranslator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Icon="Assets/logo.ico"
        SizeToContent="WidthAndHeight"
        MinHeight="220"
        MinWidth="680"
        Background="#F6F7FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,16,0"
                        VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource AppTitle}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#1F2937" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="13"
                           Foreground="#5B6472"
                           TextWrapping="Wrap">
                    <Run Text="{DynamicResource OpenSourceProjectPrefix}" />
                    <Hyperlink NavigateUri="https://github.com/ShadyLeaf/GenshinChatTranslator"
                               RequestNavigate="ProjectLink_RequestNavigate"
                               Foreground="#2563EB">
                        <Run Text="{DynamicResource OpenSourceProjectLinkText}" />
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <CheckBox x:Name="DebugModeCheckBox"
                          Margin="0,0,18,0"
                          VerticalAlignment="Center"
                          Checked="DebugModeCheckBox_CheckedChanged"
                          Unchecked="DebugModeCheckBox_CheckedChanged"
                          Content="{DynamicResource DebugModeLabel}" />
                <TextBlock Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="#5B6472"
                           Text="{DynamicResource UiLanguageLabel}" />
                <Button x:Name="ChineseLanguageButton"
                        MinWidth="56"
                        Height="32"
                        Padding="10,0"
                        Tag="zh-CN"
                        Click="LanguageButton_Click"
                        Content="{DynamicResource UiLanguageChineseButton}" />
                <Button x:Name="JapaneseLanguageButton"
                        MinWidth="56"
                        Height="32"
                        Margin="6,0,0,0"
                        Padding="10,0"
                        Tag="ja-JP"
                        Click="LanguageButton_Click"
                        Content="{DynamicResource UiLanguageJapaneseButton}" />
                <Button x:Name="EnglishLanguageButton"
                        MinWidth="56"
                        Height="32"
                        Margin="6,0,0,0"
                        Padding="10,0"
                        Tag="en-US"
                        Click="LanguageButton_Click"
                        Content="{DynamicResource UiLanguageEnglishButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="ToggleButton"
                            MinWidth="112"
                            Height="36"
                            Padding="18,0"
                            Click="ToggleButton_Click"
                            Content="{DynamicResource StartButton}" />
                    <Button x:Name="SnapshotButton"
                            MinWidth="112"
                            Height="36"
                            Margin="12,0,0,0"
                            Padding="18,0"
                            Visibility="Collapsed"
                            Click="SnapshotButton_Click"
                            Content="{DynamicResource SnapshotButton}" />
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#5B6472"
                               Text="{DynamicResource OcrEngineLabel}" />
                    <ComboBox x:Name="OcrEngineComboBox"
                              Grid.Row="0"
                              Grid.Column="1"
                              Height="36"
                              VerticalContentAlignment="Center"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="OcrEngineComboBox_SelectionChanged" />
                    <CheckBox x:Name="FastDetectionCheckBox"
                              Grid.Row="0"
                              Grid.Column="2"
                              Grid.ColumnSpan="3"
                              Margin="24,0,0,0"
                              VerticalAlignment="Center"
                              Checked="FastDetectionCheckBox_CheckedChanged"
                              Unchecked="FastDetectionCheckBox_CheckedChanged"
                              Content="{DynamicResource FastDetectionLabel}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,12,8,0"
                               VerticalAlignment="Center"
                               Foreground="#5B6472"
                               Text="{DynamicResource TranslationEngineLabel}" />
                    <ComboBox x:Name="TranslationEngineComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Height="36"
                              Margin="0,12,0,0"
                              VerticalContentAlignment="Center"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="TranslationEngineComboBox_SelectionChanged" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               Margin="24,12,8,0"
                               VerticalAlignment="Center"
                               Foreground="#5B6472"
                               Text="{DynamicResource TranslationTargetLanguageLabel}" />
                    <ComboBox x:Name="TranslationTargetLanguageComboBox"
                              Grid.Row="1"
                              Grid.Column="3"
                              Height="36"
                              Margin="0,12,0,0"
                              VerticalContentAlignment="Center"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="TranslationTargetLanguageComboBox_SelectionChanged" />
                    <Button x:Name="ConfigureLlmButton"
                            Grid.Row="1"
                            Grid.Column="4"
                            MinWidth="96"
                            Height="36"
                            Margin="8,12,0,0"
                            Padding="14,0"
                            Visibility="Collapsed"
                            Click="ConfigureLlmButton_Click"
                            Content="{DynamicResource ConfigureLlmButton}" />
                </Grid>

                <Grid Grid.Row="2"
                      Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="AutoFixWin11BitBltCheckBox"
                                  Grid.Column="0"
                                  VerticalAlignment="Center"
                                  Checked="AutoFixWin11BitBltCheckBox_CheckedChanged"
                                  Unchecked="AutoFixWin11BitBltCheckBox_CheckedChanged" />
                        <StackPanel Grid.Column="1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Foreground="#374151"
                                       Text="{DynamicResource AutoFixWin11BitBltLabel}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="#5B6472"
                                       FontSize="12"
                                       Text="{DynamicResource AutoFixWin11BitBltHint}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <Button Grid.Column="3"
                            HorizontalAlignment="Right"
                            MinWidth="96"
                            Height="32"
                            Padding="14,0"
                            Click="OpenDisplayAdvancedGraphicsSettingsButton_Click"
                            Content="{DynamicResource ManualGraphicsSettingsButton}" />
                </Grid>
            </Grid>

            <Border x:Name="DebugDetailsBorder"
                    Grid.Column="1"
                    Width="430"
                    Margin="18,0,0,0"
                    Padding="18"
                    Background="White"
                    BorderBrush="#D9DEE8"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,0,12"
                               Foreground="#5B6472"
                               Text="{DynamicResource TargetLabel}" />
                    <TextBlock x:Name="TargetTextBlock"
                               Grid.Row="0"
                               Grid.Column="1"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               Foreground="#111827" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,0,0,12"
                               Foreground="#5B6472"
                               Text="{DynamicResource CaptureLabel}" />
                    <TextBlock x:Name="CaptureTextBlock"
                               Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,0,0,12"
                               Foreground="#111827" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,0,0,12"
                               Foreground="#5B6472"
                               Text="{DynamicResource RoiLabel}" />
                    <TextBlock x:Name="RoiTextBlock"
                               Grid.Row="2"
                               Grid.Column="1"
                               Margin="0,0,0,12"
                               Foreground="#111827" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Margin="0,0,0,12"
                               Foreground="#5B6472"
                               Text="{DynamicResource OcrLabel}" />
                    <TextBlock x:Name="OcrTextBlock"
                               Grid.Row="3"
                               Grid.Column="1"
                               Margin="0,0,0,12"
                               Foreground="#111827" />

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Margin="0,0,0,12"
                               Foreground="#5B6472"
                               Text="{DynamicResource TranslationLabel}" />
                    <TextBlock x:Name="TranslationTextBlock"
                               Grid.Row="4"
                               Grid.Column="1"
                               Margin="0,0,0,12"
                               Foreground="#111827" />

                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Margin="0,0,0,12"
                               Foreground="#5B6472"
                               Text="{DynamicResource RecognitionSummaryLabel}" />
                    <TextBlock x:Name="RecognitionSummaryTextBlock"
                               Grid.Row="5"
                               Grid.Column="1"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               Foreground="#111827" />

                    <TextBlock Grid.Row="6"
                               Grid.Column="0"
                               Foreground="#5B6472"
                               Text="{DynamicResource LatencyLabel}" />
                    <TextBlock x:Name="LatencyTextBlock"
                               Grid.Row="6"
                               Grid.Column="1"
                               TextWrapping="Wrap"
                               Foreground="#111827" />
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="2"
                   Margin="0,18,0,0"
                   Foreground="#374151"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />
    </Grid>
</Window>
