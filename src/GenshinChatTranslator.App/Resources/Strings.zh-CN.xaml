    <sys:String x:Key="LlmConfigApiKeyMissing">当前没有可用 API Key。</sys:String>
    <sys:String x:Key="LlmConfigRequiredFieldsMissing">URL 和模型名称不能为空。</sys:String>
    <sys:String x:Key="LlmConfigValidating">正在校验 LLM 服务...</sys:String>
    <sys:String x:Key="LlmConfigValidationFailedFormat">校验失败：{0}</sys:String>
